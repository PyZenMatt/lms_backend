# Production environment configuration template
# Copy to .env and fill in your actual values

# Django settings
DJANGO_SETTINGS_MODULE=schoolplatform.settings.prod
ENVIRONMENT=production
SECRET_KEY=your_secret_key_here

# Production URLs (replace with your actual domains)
ALLOWED_HOSTS=lms-api.onrender.com,www.lms-api.onrender.com
CORS_ALLOWED_ORIGINS=https://corsi.openpython.it,https://www.corsi.openpython.it
CSRF_TRUSTED_ORIGINS=https://corsi.openpython.it,https://www.corsi.openpython.it,https://lms-api.onrender.com

# Database (replace with your actual database URL)
DATABASE_URL=postgres://username:password@hostname:port/database_name

# Security settings
DEBUG=False
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SAMESITE=None
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=True

# Email configuration (replace with your credentials)
DEFAULT_FROM_EMAIL=your_email@example.com
EMAIL_HOST=smtp.example.com
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_HOST_USER=your_email@example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Celery/Redis (replace with your Redis URL)
CELERY_BROKER_URL=your_redis_url
CELERY_RESULT_BACKEND=your_redis_url
REDIS_URL=your_redis_url
CELERY_WORKER_CONCURRENCY=4

# Stripe (replace with your actual keys - NEVER commit real keys!)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
ENFORCE_STRIPE=1

# Blockchain/Wallet settings (replace with your keys)
ADMIN_PRIVATE_KEY=your_admin_private_key
ADMIN_WALLET_ADDRESS=your_admin_wallet_address
PLATFORM_PRIVATE_KEY=your_platform_private_key
PLATFORM_WALLET_ADDRESS=your_platform_wallet_address

# TeoCoin System
TEOCOIN_SYSTEM=database
USE_DB_TEOCOIN_SYSTEM=True
REWARD_SYSTEM_BACKEND=services.db_teocoin_service.DBTeoCoinService

# Database SSL
DB_SSL_REQUIRE=1

# Optional: Sentry for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Production server
PORT=8000